# --- App -------------------------------------------------------------------
PORT=3000
# DB_PATH=./psa.sqlite
# APP_TIMEZONE=Australia/Perth   # fallback — Settings page value wins

# --- Access (set before exposing off localhost) ----------------------------
APP_PASSWORD=
# SESSION_SECRET=               # defaults to APP_PASSWORD
# COOKIE_SECURE=1               # auto when XERO_REDIRECT_URI is https

# --- Xero (https://developer.xero.com/app/manage) --------------------------
# App type: Web app. Redirect URI must match exactly (https off localhost).
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3000/auth/xero/callback

# --- Pax8 (Partner portal → Integrations → API credentials) ----------------
PAX8_CLIENT_ID=
PAX8_CLIENT_SECRET=

# --- Microsoft 365 / Graph (Entra app registration, app-only) --------------
# Permissions (admin consent): Mail.ReadWrite, Mail.Send
# Scope to support mailbox via ApplicationAccessPolicy (recommended).
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
SUPPORT_MAILBOX=support@yourdomain.com.au

# --- Telegram (optional: tickets + billing from chat) ------------------------
# 1. @BotFather → /newbot → copy token
# 2. Message bot, then https://api.telegram.org/bot<TOKEN>/getUpdates for chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# --- Microsoft Teams webhook (optional: digest + nudges) -------------------
# Teams channel → Workflows → "Post when webhook request received"
TEAMS_WEBHOOK_URL=

# --- Microsoft Teams bot (optional: interactive chat) ----------------------
# Requires public HTTPS — messages delivered to https://<host>/teams/messages
# 1. Entra → App registrations → copy Application ID + client secret
# 2. Azure → Azure Bot (F0) → link app → Messaging endpoint: https://<host>/teams/messages
# 3. Send bot a message to get your user id for TEAMS_BOT_ALLOWED_USER_ID
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_PASSWORD=
TEAMS_BOT_ALLOWED_USER_ID=
# TEAMS_BOT_TENANT_ID=

# --- Claude assistant (optional: natural language on web + chat bots) --------
# https://console.anthropic.com — model chosen on Settings page
ANTHROPIC_API_KEY=
